rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "rebelroots.voice@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function isStaffOrAdmin() {
      return isAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff');
    }
    
    function isBoardStaffOrAdmin() {
      return isStaffOrAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'board');
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 150 &&
             data.role in ['admin', 'staff', 'board', 'volunteer'];
    }

    function isValidContact(data) {
      return hasOnlyAllowedFields(['id', 'firstName', 'lastName', 'email', 'phone', 'type', 'totalDonated', 'tags', 'createdAt', 'updatedAt', 'skills', 'availability', 'hoursLogged']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.firstName is string && data.firstName.size() > 0 && data.firstName.size() < 100 &&
             data.lastName is string && data.lastName.size() > 0 && data.lastName.size() < 100 &&
             data.type in ['donor', 'grantor', 'sponsor', 'volunteer'] &&
             (!('skills' in data) || data.skills is list) &&
             (!('availability' in data) || data.availability is string) &&
             (!('hoursLogged' in data) || data.hoursLogged is number);
    }

    function isValidDonation(data) {
      return hasOnlyAllowedFields(['id', 'contactId', 'donorName', 'amount', 'donationType', 'itemDescription', 'receiptSent', 'date', 'source', 'fund', 'campaign', 'status', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.contactId is string && data.contactId.size() > 0 && data.contactId.size() < 100 &&
             (!('donorName' in data) || data.donorName == null || (data.donorName is string && data.donorName.size() < 200)) &&
             data.amount is number && data.amount >= 0 &&
             data.donationType in ['monetary', 'in-kind'] &&
             (!('itemDescription' in data) || data.itemDescription == null || (data.itemDescription is string && data.itemDescription.size() < 1000)) &&
             (!('receiptSent' in data) || data.receiptSent == null || data.receiptSent is bool) &&
             data.source in ['zeffy', 'manual', 'check'] &&
             data.status in ['pending', 'completed', 'failed'];
    }

    function isValidVolunteerLog(data) {
      return hasOnlyAllowedFields(['id', 'contactId', 'volunteerName', 'hours', 'date', 'activity', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.contactId is string && data.contactId.size() > 0 && data.contactId.size() < 100 &&
             data.hours is number && data.hours >= 0 &&
             data.date is string && data.date.size() > 0 && data.date.size() < 50;
    }

    function isValidTask(data) {
      return hasOnlyAllowedFields(['id', 'title', 'description', 'assignedTo', 'dueDate', 'status', 'module', 'relatedRecordId', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.status in ['todo', 'in-progress', 'done'] &&
             data.module in ['compliance', 'donors', 'bookkeeping', 'board'];
    }

    function isValidTransaction(data) {
      return hasOnlyAllowedFields(['id', 'date', 'description', 'amount', 'type', 'category', 'status', 'receiptUrl', 'createdAt', 'updatedAt', 'createdBy']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.date is string && data.date.size() > 0 && data.date.size() < 50 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 500 &&
             data.amount is number && data.amount >= 0 &&
             data.type in ['income', 'expense'] &&
             data.category in ['donation', 'grant', 'operational', 'program', 'other', 'uncategorized'] &&
             data.status in ['pending', 'reconciled'] &&
             (!('receiptUrl' in data) || data.receiptUrl == null || (data.receiptUrl is string && data.receiptUrl.size() < 1000));
    }

    function isValidComplianceItem(data) {
      return hasOnlyAllowedFields(['id', 'title', 'description', 'type', 'dueDate', 'status', 'assignedTo', 'documentUrl', 'createdAt', 'updatedAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.type in ['filing', 'policy', 'report', 'other'] &&
             data.status in ['pending', 'submitted', 'approved', 'overdue'] &&
             (!('description' in data) || data.description == null || (data.description is string && data.description.size() < 1000)) &&
             (!('documentUrl' in data) || data.documentUrl == null || (data.documentUrl is string && data.documentUrl.size() < 1000));
    }

    function isValidBoardMember(data) {
      return hasOnlyAllowedFields(['id', 'name', 'email', 'phone', 'status', 'resumeUrl', 'specialties', 'experiences', 'onboardingProgress', 'joinedDate', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.status in ['candidate', 'active', 'former'] &&
             (!('email' in data) || data.email == null || (data.email is string && data.email.size() < 150)) &&
             (!('phone' in data) || data.phone == null || (data.phone is string && data.phone.size() < 50)) &&
             (!('resumeUrl' in data) || data.resumeUrl == null || (data.resumeUrl is string && data.resumeUrl.size() < 1000)) &&
             (!('specialties' in data) || data.specialties == null || data.specialties is list) &&
             (!('experiences' in data) || data.experiences == null || (data.experiences is string && data.experiences.size() < 5000)) &&
             (!('onboardingProgress' in data) || data.onboardingProgress == null || (data.onboardingProgress is number && data.onboardingProgress >= 0 && data.onboardingProgress <= 100)) &&
             (!('joinedDate' in data) || data.joinedDate == null || (data.joinedDate is string && data.joinedDate.size() < 50));
    }

    function isValidBoardMeetingMinute(data) {
      return hasOnlyAllowedFields(['id', 'date', 'title', 'content', 'source', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.date is string && data.date.size() > 0 && data.date.size() < 50 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 100000 &&
             data.source in ['manual', 'zoom_ai'];
    }

    function isValidBoardProject(data) {
      return hasOnlyAllowedFields(['id', 'title', 'description', 'leadMemberId', 'phase', 'team', 'budget', 'resources', 'supplies', 'proposalsPassed', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.phase in ['planning', 'active', 'completed', 'failed'] &&
             (!('description' in data) || data.description == null || (data.description is string && data.description.size() < 5000)) &&
             (!('leadMemberId' in data) || data.leadMemberId == null || (data.leadMemberId is string && data.leadMemberId.size() < 100)) &&
             (!('team' in data) || data.team == null || data.team is list) &&
             (!('budget' in data) || data.budget == null || (data.budget is number && data.budget >= 0)) &&
             (!('resources' in data) || data.resources == null || (data.resources is string && data.resources.size() < 2000)) &&
             (!('supplies' in data) || data.supplies == null || (data.supplies is string && data.supplies.size() < 2000)) &&
             (!('proposalsPassed' in data) || data.proposalsPassed == null || data.proposalsPassed is list);
    }

    function isValidOrganizationSettings(data) {
      return hasOnlyAllowedFields(['fiscalYearEnd', 'states', 'updatedAt']) &&
             data.fiscalYearEnd is string && data.fiscalYearEnd.matches('^\\d{2}-\\d{2}$') &&
             data.states is list &&
             data.updatedAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && request.resource.data.role == 'volunteer') || isAdmin()
      );
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /contacts/{contactId} {
      allow read: if isBoardStaffOrAdmin();
      allow create: if isStaffOrAdmin() && isValidContact(request.resource.data);
      allow update: if isStaffOrAdmin() && isValidContact(request.resource.data);
      allow delete: if isAdmin();
    }

    match /donations/{donationId} {
      allow read: if isBoardStaffOrAdmin();
      allow create: if isStaffOrAdmin() && isValidDonation(request.resource.data);
      allow update: if isStaffOrAdmin() && isValidDonation(request.resource.data);
      allow delete: if isAdmin();
    }

    match /volunteerHours/{logId} {
      allow read: if isBoardStaffOrAdmin();
      allow create: if isStaffOrAdmin() && isValidVolunteerLog(request.resource.data);
      allow update: if isStaffOrAdmin() && isValidVolunteerLog(request.resource.data);
      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if isAuthenticated() && isValidTask(request.resource.data);
      allow delete: if isStaffOrAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isBoardStaffOrAdmin();
      allow create: if isStaffOrAdmin() && isValidTransaction(request.resource.data);
      allow update: if isStaffOrAdmin() && isValidTransaction(request.resource.data);
      allow delete: if isAdmin();
    }

    match /compliance/{complianceId} {
      allow read: if isAuthenticated() || resource.data.status == 'approved';
      allow create: if isStaffOrAdmin() && isValidComplianceItem(request.resource.data);
      allow update: if isStaffOrAdmin() && isValidComplianceItem(request.resource.data);
      allow delete: if isAdmin();
    }

    match /boardMembers/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isBoardStaffOrAdmin() && isValidBoardMember(request.resource.data);
      allow update: if isBoardStaffOrAdmin() && isValidBoardMember(request.resource.data);
      allow delete: if isAdmin();
    }

    match /boardMinutes/{minuteId} {
      allow read: if isAuthenticated();
      allow create: if isBoardStaffOrAdmin() && isValidBoardMeetingMinute(request.resource.data);
      allow update: if isBoardStaffOrAdmin() && isValidBoardMeetingMinute(request.resource.data);
      allow delete: if isAdmin();
    }

    match /boardProjects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isBoardStaffOrAdmin() && isValidBoardProject(request.resource.data);
      allow update: if isBoardStaffOrAdmin() && isValidBoardProject(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/org {
      allow read: if isAuthenticated();
      allow write: if isStaffOrAdmin() && isValidOrganizationSettings(request.resource.data);
    }
  }
}
