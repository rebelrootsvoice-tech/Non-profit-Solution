{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Nonprofit OS platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff", "board", "volunteer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "A donor, grantor, or other contact.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "type": { "type": "string", "enum": ["donor", "grantor", "sponsor", "volunteer"] },
        "totalDonated": { "type": "number" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "type", "createdAt"]
    },
    "Donation": {
      "title": "Donation",
      "description": "A donation record, often synced from Zeffy.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "contactId": { "type": "string" },
        "donorName": { "type": "string" },
        "amount": { "type": "number" },
        "donationType": { "type": "string", "enum": ["monetary", "in-kind"] },
        "itemDescription": { "type": "string" },
        "receiptSent": { "type": "boolean" },
        "date": { "type": "string", "format": "date-time" },
        "source": { "type": "string", "enum": ["zeffy", "manual", "check"] },
        "fund": { "type": "string" },
        "campaign": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "contactId", "amount", "donationType", "date", "source", "status", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A task for a user, often generated automatically.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedTo": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "done"] },
        "module": { "type": "string", "enum": ["compliance", "donors", "bookkeeping", "board"] },
        "relatedRecordId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "status", "module", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A bookkeeping transaction (income or expense).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string", "enum": ["donation", "grant", "operational", "program", "other", "uncategorized"] },
        "status": { "type": "string", "enum": ["pending", "reconciled"] },
        "receiptUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["id", "date", "description", "amount", "type", "category", "status", "createdAt"]
    },
    "ComplianceItem": {
      "title": "Compliance Item",
      "description": "A compliance requirement, filing, or policy review.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["filing", "policy", "report", "other"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "submitted", "approved", "overdue"] },
        "assignedTo": { "type": "string" },
        "documentUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "type", "dueDate", "status", "createdAt"]
    },
    "BoardMember": {
      "title": "Board Member",
      "description": "A board member profile, including candidates.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["candidate", "active", "former"] },
        "resumeUrl": { "type": "string" },
        "specialties": { "type": "array", "items": { "type": "string" } },
        "experiences": { "type": "string" },
        "onboardingProgress": { "type": "number" },
        "joinedDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "status", "createdAt"]
    },
    "BoardMeetingMinute": {
      "title": "Board Meeting Minute",
      "description": "Minutes from board meetings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "source": { "type": "string", "enum": ["manual", "zoom_ai"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "date", "title", "content", "source", "createdAt"]
    },
    "BoardProject": {
      "title": "Board Project",
      "description": "Projects and proposals managed by board members.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "leadMemberId": { "type": "string" },
        "phase": { "type": "string", "enum": ["planning", "active", "completed", "failed"] },
        "team": { "type": "array", "items": { "type": "string" } },
        "budget": { "type": "number" },
        "resources": { "type": "string" },
        "supplies": { "type": "string" },
        "proposalsPassed": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "phase", "createdAt"]
    },
    "VolunteerLog": {
      "title": "Volunteer Log",
      "description": "A record of volunteer hours logged.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "contactId": { "type": "string" },
        "volunteerName": { "type": "string" },
        "hours": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "activity": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "contactId", "hours", "date", "createdAt"]
    },
    "OrganizationSettings": {
      "title": "Organization Settings",
      "description": "Global settings for the organization.",
      "type": "object",
      "properties": {
        "fiscalYearEnd": { "type": "string", "description": "MM-DD format" },
        "states": { "type": "array", "items": { "type": "string" }, "description": "List of states the org operates in" },
        "ein": { "type": "string" },
        "uei": { "type": "string" },
        "samRenewalDate": { "type": "string", "format": "date" },
        "hasUBI": { "type": "boolean" },
        "receivesGovtFunds": { "type": "boolean" },
        "readiness": {
          "type": "object",
          "properties": {
            "irsDeterminationLetter": { "type": "string" },
            "articlesOfIncorporation": { "type": "string" },
            "bylaws": { "type": "string" },
            "prior990s": { "type": "string" },
            "payrollSystemConfirmed": { "type": "boolean" },
            "sosStanding": { "type": "string" },
            "charitablePermit": { "type": "string" },
            "salesTaxExemption": { "type": "string" },
            "coiPolicy": { "type": "boolean" },
            "whistleblowerPolicy": { "type": "boolean" },
            "retentionPolicy": { "type": "boolean" },
            "boardMinutes": { "type": "string" },
            "procurementPolicy": { "type": "boolean" },
            "timeEffortTracking": { "type": "boolean" },
            "indirectCostRate": { "type": "string" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fiscalYearEnd", "states"]
    }
  },
  "firestore": {
    "/settings/org": {
      "schema": { "$ref": "#/entities/OrganizationSettings" },
      "description": "Global organization settings."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and roles."
    },
    "/contacts/{contactId}": {
      "schema": { "$ref": "#/entities/Contact" },
      "description": "Master contact records (donors, grantors, etc.)."
    },
    "/donations/{donationId}": {
      "schema": { "$ref": "#/entities/Donation" },
      "description": "Donation records."
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Tasks across all modules."
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Bookkeeping transactions."
    },
    "/compliance/{complianceId}": {
      "schema": { "$ref": "#/entities/ComplianceItem" },
      "description": "Compliance requirements, filings, and policy reviews."
    },
    "/boardMembers/{memberId}": {
      "schema": { "$ref": "#/entities/BoardMember" },
      "description": "Board members and candidates."
    },
    "/boardMinutes/{minuteId}": {
      "schema": { "$ref": "#/entities/BoardMeetingMinute" },
      "description": "Board meeting minutes."
    },
    "/boardProjects/{projectId}": {
      "schema": { "$ref": "#/entities/BoardProject" },
      "description": "Board projects and proposals."
    },
    "/volunteerHours/{logId}": {
      "schema": { "$ref": "#/entities/VolunteerLog" },
      "description": "Volunteer hour logs."
    }
  }
}
